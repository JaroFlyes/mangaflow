# Banco de dados
DATABASE_URL="postgresql://user:password@localhost:5432/mangaflow"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Armazenamento de imagens (S3 compatível)
STORAGE_BUCKET_NAME="mangaflow"
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY_ID="your-access-key"
STORAGE_SECRET_ACCESS_KEY="your-secret-key"
STORAGE_ENDPOINT="https://s3.amazonaws.com" # ou endpoint Supabase/Wasabi
STORAGE_PUBLIC_URL="https://seu-bucket.s3.amazonaws.com"
